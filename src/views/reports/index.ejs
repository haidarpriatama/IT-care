<%
  const statusLabel = (value) => ({ open: 'Open', in_progress: 'Dalam proses', resolved: 'Selesai', rejected: 'Ditolak' }[value] || value || '-');
  const priorityLabel = (value) => ({ high: 'Tinggi', medium: 'Sedang', low: 'Rendah' }[value] || value || '-');
%>
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Laporan operasional IT Care Helpdesk">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/navbar') %>

      <main class="page-content">
        <section class="page-header">
          <div>
            <h1>Laporan</h1>
            <p>Rekap gabungan tiket, user, kategori, dan histori status untuk monitoring operasional helpdesk.</p>
          </div>
        </section>

        <section class="metric-strip page-section">
          <div class="metric-card"><p class="metric-label">Total Tiket</p><div class="metric-value"><%= summary.total %></div><div class="metric-meta">Semua tiket aktif</div></div>
          <div class="metric-card"><p class="metric-label">Open</p><div class="metric-value"><%= summary.open %></div><div class="metric-meta">Menunggu penanganan</div></div>
          <div class="metric-card"><p class="metric-label">Dalam Proses</p><div class="metric-value"><%= summary.in_progress %></div><div class="metric-meta">Sedang dikerjakan</div></div>
          <div class="metric-card"><p class="metric-label">Selesai</p><div class="metric-value"><%= summary.resolved %></div><div class="metric-meta">Terselesaikan</div></div>
          <div class="metric-card"><p class="metric-label">Ditolak</p><div class="metric-value"><%= summary.rejected %></div><div class="metric-meta">Tidak diproses</div></div>
        </section>

        <div class="analytics-layout page-section">
          <section class="data-card card-custom">
            <div class="card-header-custom">
              <div>
                <h2 class="panel-title">Distribusi kategori</h2>
                <div class="section-subtitle">Volume tiket per kategori aktif.</div>
              </div>
            </div>
            <div class="card-body-custom">
              <% if (categoryStats.length === 0) { %>
              <div class="empty-state compact">
                <i class="bi bi-bar-chart"></i>
                <h4>Belum ada data</h4>
                <p>Kategori akan muncul di sini setelah tiket mulai tercatat.</p>
              </div>
              <% } else { %>
                <% const maxCount = Math.max(...categoryStats.map(c => parseInt(c.total) || 0), 1); %>
                <div class="progress-list">
                  <% categoryStats.forEach(cs => { %>
                  <div class="progress-row">
                    <div class="progress-head">
                      <span class="progress-label"><%= cs.name %></span>
                      <span class="text-muted-sm"><%= cs.total %></span>
                    </div>
                    <div class="progress-track">
                      <div class="progress-fill" style="width:<%= Math.round((parseInt(cs.total) / maxCount) * 100) %>%"></div>
                    </div>
                  </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </section>

          <section class="form-panel data-card">
            <div class="card-header-custom">
              <div>
                <h2 class="panel-title">Filter laporan</h2>
                <div class="section-subtitle">Gunakan filter untuk mempersempit data operasional.</div>
              </div>
              <% if (filters.search || filters.status || filters.priority || filters.category_id || filters.date_from || filters.date_to) { %>
              <a href="/reports" class="btn-secondary-app">Reset</a>
              <% } %>
            </div>
            <div class="card-body-custom">
              <form method="GET" action="/reports" id="reportFilterForm">
                <div class="form-grid-2">
                  <div class="form-group">
                    <label class="form-label-custom" for="reportSearch">Cari</label>
                    <input type="text" name="search" id="reportSearch" class="form-control-custom" placeholder="Judul, pemohon, departemen..." value="<%= filters.search %>">
                  </div>
                  <div class="form-group">
                    <label class="form-label-custom" for="catFilter">Kategori</label>
                    <select name="category_id" id="catFilter" class="form-control-custom">
                      <option value="">Semua Kategori</option>
                      <% categories.forEach(cat => { %>
                      <option value="<%= cat.id %>" <%= filters.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="form-group">
                    <label class="form-label-custom" for="reportStatus">Status</label>
                    <select name="status" id="reportStatus" class="form-control-custom">
                      <option value="">Semua Status</option>
                      <option value="open" <%= filters.status === 'open' ? 'selected' : '' %>>Open</option>
                      <option value="in_progress" <%= filters.status === 'in_progress' ? 'selected' : '' %>>Dalam proses</option>
                      <option value="resolved" <%= filters.status === 'resolved' ? 'selected' : '' %>>Selesai</option>
                      <option value="rejected" <%= filters.status === 'rejected' ? 'selected' : '' %>>Ditolak</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label class="form-label-custom" for="reportPriority">Prioritas</label>
                    <select name="priority" id="reportPriority" class="form-control-custom">
                      <option value="">Semua Prioritas</option>
                      <option value="high" <%= filters.priority === 'high' ? 'selected' : '' %>>Tinggi</option>
                      <option value="medium" <%= filters.priority === 'medium' ? 'selected' : '' %>>Sedang</option>
                      <option value="low" <%= filters.priority === 'low' ? 'selected' : '' %>>Rendah</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label class="form-label-custom" for="dateFrom">Dari Tanggal</label>
                    <input type="date" name="date_from" id="dateFrom" class="form-control-custom" value="<%= filters.date_from %>">
                  </div>
                  <div class="form-group">
                    <label class="form-label-custom" for="dateTo">Sampai Tanggal</label>
                    <input type="date" name="date_to" id="dateTo" class="form-control-custom" value="<%= filters.date_to %>">
                  </div>
                </div>

                <div class="form-actions">
                  <button type="submit" class="btn-primary-app">Terapkan Filter</button>
                </div>
              </form>
            </div>
          </section>
        </div>

        <section class="data-card card-custom">
          <div class="card-header-custom">
            <div>
              <h2 class="panel-title">Data Laporan</h2>
              <div class="section-subtitle"><%= tickets.length %> tiket sesuai filter aktif.</div>
            </div>
          </div>

          <% if (tickets.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-file-earmark-text"></i>
            <h4>Tidak ada data laporan</h4>
            <p>Tidak ada tiket yang sesuai dengan filter yang dipilih.</p>
          </div>
          <% } else { %>
          <div class="table-wrap">
            <table class="data-table table-custom">
              <thead>
                <tr>
                  <th>#ID</th>
                  <th>Judul Tiket</th>
                  <th>Pemohon</th>
                  <th>Departemen</th>
                  <th>Kategori</th>
                  <th>Teknisi</th>
                  <th>Prioritas</th>
                  <th>Status</th>
                  <th>Status Terakhir</th>
                  <th>Catatan</th>
                  <th>Lokasi</th>
                  <th>Tanggal</th>
                </tr>
              </thead>
              <tbody>
                <% tickets.forEach(ticket => { %>
                <tr>
                  <td><a href="/tickets/<%= ticket.id %>" class="id-link">#<%= ticket.id %></a></td>
                  <td><a href="/tickets/<%= ticket.id %>" class="ticket-title"><%= ticket.title %></a></td>
                  <td><%= ticket.requester_name %></td>
                  <td class="text-muted-sm"><%= ticket.requester_dept || '-' %></td>
                  <td><% if (ticket.category_name) { %><span class="chip"><%= ticket.category_name %></span><% } else { %><span class="text-muted-sm">-</span><% } %></td>
                  <td><%= ticket.technician_name || '-' %></td>
                  <td><span class="badge-priority badge-<%= ticket.priority %>"><%= priorityLabel(ticket.priority) %></span></td>
                  <td><span class="badge-status badge-<%= ticket.status %>"><%= statusLabel(ticket.status) %></span></td>
                  <td><% if (ticket.last_status) { %><span class="badge-status badge-<%= ticket.last_status %>"><%= statusLabel(ticket.last_status) %></span><% } else { %><span class="text-muted-sm">-</span><% } %></td>
                  <td><%= ticket.note_count %></td>
                  <td class="text-muted-sm"><%= ticket.location || '-' %></td>
                  <td class="text-muted-sm"><%= new Date(ticket.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </section>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
