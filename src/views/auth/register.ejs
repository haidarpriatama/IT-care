<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Register - IT Care' %></title>
  <meta name="description" content="Daftar akun IT Care Helpdesk">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="auth-wrapper">
    <div class="auth-card" style="max-width:520px;">
      <div class="auth-logo">
        <div class="logo-icon"><i class="bi bi-shield-check"></i></div>
        <h1>IT<span>Care</span></h1>
      </div>
      <p class="auth-subtitle">Daftarkan akun baru Anda</p>

      <form action="/register" method="POST" id="registerForm">

        <div class="form-group">
          <label class="form-label-custom" for="name">Nama Lengkap</label>
          <div class="input-group">
            <span class="input-group-text" style="border-radius:10px 0 0 10px; border:1.5px solid #e2e8f0; border-right:none; background:#f8fafc;">
              <i class="bi bi-person" style="color:#94a3b8;"></i>
            </span>
            <input type="text" name="name" id="name" class="form-control-custom" style="border-radius:0 10px 10px 0;"
              placeholder="Nama lengkap Anda" required>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label-custom" for="email">Email</label>
          <div class="input-group">
            <span class="input-group-text" style="border-radius:10px 0 0 10px; border:1.5px solid #e2e8f0; border-right:none; background:#f8fafc;">
              <i class="bi bi-envelope" style="color:#94a3b8;"></i>
            </span>
            <input type="email" name="email" id="email" class="form-control-custom" style="border-radius:0 10px 10px 0;"
              placeholder="email@company.com" required>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label-custom" for="regPassword">Password</label>
          <div class="input-group">
            <span class="input-group-text" style="border-radius:10px 0 0 10px; border:1.5px solid #e2e8f0; border-right:none; background:#f8fafc;">
              <i class="bi bi-lock" style="color:#94a3b8;"></i>
            </span>
            <input type="password" name="password" id="regPassword" class="form-control-custom"
              style="border-radius:0 10px 10px 0;" placeholder="Min. 6 karakter" required minlength="6">
            <button type="button" class="btn-icon" style="border-radius:0 10px 10px 0; border-left:none;"
              onclick="togglePassword()">
              <i class="bi bi-eye" id="regToggleIcon"></i>
            </button>
          </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
          <div class="form-group">
            <label class="form-label-custom" for="role">Role</label>
            <select name="role" id="role" class="form-control-custom">
              <option value="karyawan" selected>Karyawan</option>
              <option value="teknisi">Teknisi</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label-custom" for="department">Departemen</label>
            <input type="text" name="department" id="department" class="form-control-custom"
              placeholder="Finance, HR, IT...">
          </div>
        </div>

        <div class="form-group">
          <label class="form-label-custom" for="phone">Nomor Telepon</label>
          <input type="text" name="phone" id="phone" class="form-control-custom" placeholder="08xxxxxxxxxx">
        </div>

        <button type="submit" class="btn-primary-custom w-100 justify-content-center mt-2" style="padding:.75rem;">
          <i class="bi bi-person-plus"></i> Daftar Sekarang
        </button>
      </form>

      <div class="text-center mt-4" style="font-size:.85rem; color:#64748b;">
        Sudah punya akun? <a href="/login" style="color:#4f46e5; font-weight:600;">Masuk di sini</a>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
  <script>
    function togglePassword() {
      const p = document.getElementById('regPassword');
      const icon = document.getElementById('regToggleIcon');
      p.type = p.type === 'password' ? 'text' : 'password';
      icon.className = p.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
    }
  </script>
</body>
</html>
