<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Edit user IT Care">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/navbar') %>
      <div class="page-content">

        <div class="action-bar">
          <div>
            <div class="action-bar-title"><i class="bi bi-pencil-square" style="color:var(--accent);"></i> Edit User: <%= editUser.name %></div>
          </div>
          <a href="/users" class="btn-secondary-custom">
            <i class="bi bi-arrow-left"></i> Kembali
          </a>
        </div>

        <div style="max-width:600px;">
          <div class="card-custom">
            <div class="card-header-custom">
              <div class="card-title-custom"><i class="bi bi-person-badge"></i> Edit Informasi Akun</div>
            </div>
            <div class="card-body-custom">
              <form action="/users/<%= editUser.id %>?_method=PUT" method="POST">

                <div class="form-group">
                  <label class="form-label-custom" for="name">Nama Lengkap *</label>
                  <input type="text" id="name" name="name" class="form-control-custom"
                    value="<%= editUser.name %>" required maxlength="150">
                </div>

                <div class="form-group">
                  <label class="form-label-custom" for="email">Email *</label>
                  <input type="email" id="email" name="email" class="form-control-custom"
                    value="<%= editUser.email %>" required>
                </div>

                <div class="form-group">
                  <label class="form-label-custom" for="password">
                    Password Baru
                    <span style="font-size:.75rem; color:var(--text-muted); font-weight:400;">(kosongkan jika tidak diubah)</span>
                  </label>
                  <div style="position:relative;">
                    <input type="password" id="password" name="password" class="form-control-custom"
                      placeholder="Isi untuk mengganti password..." minlength="6">
                    <button type="button" class="btn-icon" onclick="togglePwd('password','eyeIcon')"
                      style="position:absolute; right:.5rem; top:50%; transform:translateY(-50%); border:none;">
                      <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                  </div>
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.25rem;">
                  <div class="form-group">
                    <label class="form-label-custom" for="role">Role *</label>
                    <select id="role" name="role" class="form-control-custom" required>
                      <option value="karyawan" <%= editUser.role === 'karyawan' ? 'selected' : '' %>>Karyawan</option>
                      <option value="teknisi" <%= editUser.role === 'teknisi' ? 'selected' : '' %>>Teknisi</option>
                      <option value="admin" <%= editUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label class="form-label-custom" for="department">Departemen</label>
                    <input type="text" id="department" name="department" class="form-control-custom"
                      value="<%= editUser.department || '' %>" placeholder="Finance, HR, IT...">
                  </div>
                </div>

                <div class="form-group">
                  <label class="form-label-custom" for="phone">Nomor Telepon</label>
                  <input type="text" id="phone" name="phone" class="form-control-custom"
                    value="<%= editUser.phone || '' %>">
                </div>

                <div style="display:flex; gap:.75rem; border-top:1px solid var(--border); padding-top:1.25rem; margin-top:.5rem;">
                  <button type="submit" class="btn-primary-custom">
                    <i class="bi bi-floppy"></i> Simpan Perubahan
                  </button>
                  <a href="/users" class="btn-secondary-custom">Batal</a>
                </div>

              </form>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
  <script>
    function togglePwd(inputId, iconId) {
      const p = document.getElementById(inputId);
      const i = document.getElementById(iconId);
      p.type = p.type === 'password' ? 'text' : 'password';
      i.className = p.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
    }
  </script>
</body>
</html>
