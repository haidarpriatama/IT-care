<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Manajemen user IT Care">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/navbar') %>

      <main class="page-content">
        <section class="page-header">
          <div>
            <h1>Users</h1>
            <p>Kelola akun pengguna yang memiliki akses ke sistem helpdesk internal.</p>
            <div class="page-header-meta">
              <span class="badge-count"><%= users.length %> user</span>
            </div>
          </div>
        </section>

        <section class="data-card card-custom">
          <div class="toolbar">
            <form method="GET" action="/users" class="toolbar-search toolbar-search-inline" role="search">
              <div class="toolbar-search-main">
                <i class="bi bi-search"></i>
                <input type="text" name="search" class="toolbar-search-field search-input" placeholder="Cari nama, email, atau departemen..." value="<%= search %>" id="userSearch">
              </div>
              <select name="role" id="roleFilter" class="toolbar-select" data-auto-submit>
                <option value="">Semua Role</option>
                <option value="admin" <%= roleFilter === 'admin' ? 'selected' : '' %>>Admin</option>
                <option value="teknisi" <%= roleFilter === 'teknisi' ? 'selected' : '' %>>Teknisi</option>
                <option value="karyawan" <%= roleFilter === 'karyawan' ? 'selected' : '' %>>Karyawan</option>
              </select>
              <button type="submit" class="btn-secondary-app">Cari</button>
              <% if (search || roleFilter) { %>
              <a href="/users" class="btn-secondary-app">Reset</a>
              <% } %>
            </form>

            <div class="toolbar-controls">
              <a href="/users/create" class="btn-primary-app" id="btnCreateUser">Tambah User</a>
            </div>
          </div>

          <% if (users.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-people"></i>
            <h4>Tidak ada user ditemukan</h4>
            <p><a href="/users/create">Tambah user baru</a> untuk mulai mengelola akses sistem.</p>
          </div>
          <% } else { %>
          <div class="table-wrap">
            <table class="data-table table-custom">
              <thead>
                <tr>
                  <th>#</th>
                  <th>User</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Departemen</th>
                  <th>Telepon</th>
                  <th>Bergabung</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach((user, index) => { %>
                <tr>
                  <td class="text-muted-sm"><%= index + 1 %></td>
                  <td>
                    <div class="table-user">
                      <div class="table-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
                      <div class="cell-stack">
                        <span class="cell-title"><%= user.name %></span>
                        <% if (user.id === currentUser.id) { %><span class="cell-meta">Akun Anda</span><% } %>
                      </div>
                    </div>
                  </td>
                  <td class="text-muted-sm"><%= user.email %></td>
                  <td><span class="badge-role-<%= user.role %>"><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></span></td>
                  <td><%= user.department || '-' %></td>
                  <td><%= user.phone || '-' %></td>
                  <td class="text-muted-sm"><%= new Date(user.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                  <td>
                    <div class="table-actions action-inline">
                      <a href="/users/<%= user.id %>/edit" class="btn-icon-app" title="Edit User"><i class="bi bi-pencil"></i></a>
                      <% if (user.id !== currentUser.id) { %>
                      <form method="POST" action="/users/<%= user.id %>?_method=DELETE" data-confirm="Hapus user <%= user.name %>? Semua tiket yang dibuat user ini akan terhapus.">
                        <button type="submit" class="btn-icon-app danger" title="Hapus User"><i class="bi bi-trash3"></i></button>
                      </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </section>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
