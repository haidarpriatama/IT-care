<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Manajemen User IT Care">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/navbar') %>
      <div class="page-content">

        <div class="action-bar">
          <div>
            <div class="action-bar-title"><i class="bi bi-people" style="color:var(--accent);"></i> Manajemen User</div>
            <div style="font-size:.8rem; color:var(--text-muted);">Kelola akun pengguna sistem</div>
          </div>
          <a href="/users/create" class="btn-primary-custom" id="btnCreateUser">
            <i class="bi bi-person-plus"></i> Tambah User
          </a>
        </div>

        <!-- Search & Filter -->
        <div class="card-custom section-gap">
          <div class="card-body-custom" style="padding:1rem 1.5rem;">
            <form method="GET" action="/users">
              <div class="filter-bar">
                <input type="text" name="search" class="search-input"
                  placeholder="Cari nama, email, atau departemen..." value="<%= search %>"
                  id="userSearch">
                <select name="role" id="roleFilter" onchange="this.form.submit()">
                  <option value="">Semua Role</option>
                  <option value="admin" <%= roleFilter === 'admin' ? 'selected' : '' %>>Admin</option>
                  <option value="teknisi" <%= roleFilter === 'teknisi' ? 'selected' : '' %>>Teknisi</option>
                  <option value="karyawan" <%= roleFilter === 'karyawan' ? 'selected' : '' %>>Karyawan</option>
                </select>
                <button type="submit" class="btn-primary-custom">
                  <i class="bi bi-search"></i> Cari
                </button>
                <% if (search || roleFilter) { %>
                <a href="/users" class="btn-secondary-custom"><i class="bi bi-x-lg"></i> Reset</a>
                <% } %>
              </div>
            </form>
          </div>
        </div>

        <!-- Users Table -->
        <div class="card-custom">
          <% if (users.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-person-x"></i>
            <h4>Tidak ada user ditemukan</h4>
            <p><a href="/users/create" style="color:var(--accent);">Tambah user baru.</a></p>
          </div>
          <% } else { %>
          <div style="overflow-x:auto;">
            <table class="table-custom">
              <thead>
                <tr>
                  <th>#</th>
                  <th>User</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Departemen</th>
                  <th>Telepon</th>
                  <th>Bergabung</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach((user, index) => { %>
                <tr>
                  <td style="color:var(--text-muted); font-weight:600;"><%= index + 1 %></td>
                  <td>
                    <div style="display:flex; align-items:center; gap:.75rem;">
                      <div style="width:38px; height:38px; background:linear-gradient(135deg,var(--accent),#7c3aed);
                        border-radius:50%; display:flex; align-items:center; justify-content:center;
                        color:#fff; font-weight:700; font-size:.875rem; flex-shrink:0;">
                        <%= user.name.charAt(0).toUpperCase() %>
                      </div>
                      <div>
                        <div style="font-weight:600; font-size:.9rem;">
                          <%= user.name %>
                          <% if (user.id === currentUser.id) { %>
                          <span style="font-size:.65rem; background:#e0e7ff; color:#4338ca; padding:.1rem .4rem; border-radius:6px; margin-left:.25rem;">Anda</span>
                          <% } %>
                        </div>
                      </div>
                    </div>
                  </td>
                  <td style="font-size:.85rem; color:var(--text-muted);"><%= user.email %></td>
                  <td>
                    <span class="badge-role-<%= user.role %>"
                      style="font-size:.75rem; padding:.25rem .65rem; border-radius:20px; font-weight:600; display:inline-block;">
                      <i class="bi bi-<%= user.role === 'admin' ? 'shield-check' : user.role === 'teknisi' ? 'tools' : 'person' %>"></i>
                      <%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>
                    </span>
                  </td>
                  <td style="font-size:.85rem;"><%= user.department || '-' %></td>
                  <td style="font-size:.85rem;"><%= user.phone || '-' %></td>
                  <td class="text-muted-sm">
                    <%= new Date(user.created_at).toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' }) %>
                  </td>
                  <td>
                    <div style="display:flex; gap:.35rem;">
                      <a href="/users/<%= user.id %>/edit" class="btn-icon" title="Edit User">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <% if (user.id !== currentUser.id) { %>
                      <form method="POST" action="/users/<%= user.id %>?_method=DELETE" style="display:inline;"
                        onsubmit="return confirm('Hapus user <%= user.name %>? Semua tiket yang dibuat user ini akan terhapus.')">
                        <button type="submit" class="btn-icon danger" title="Hapus User">
                          <i class="bi bi-trash3"></i>
                        </button>
                      </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>

      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
