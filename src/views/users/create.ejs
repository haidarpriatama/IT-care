<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Tambah user baru IT Care">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/navbar') %>

      <main class="page-content">
        <section class="page-header">
          <div>
            <h1>Tambah User</h1>
            <p>Buat akun baru untuk admin, teknisi, atau karyawan tanpa mengubah skema data yang ada.</p>
          </div>
          <div class="page-actions">
            <a href="/users" class="btn-secondary-app">Kembali</a>
          </div>
        </section>

        <div class="row">
          <div class="col-xl-8 col-lg-9">
            <section class="form-panel data-card">
              <div class="card-header-custom">
                <div>
                  <h2 class="panel-title">Informasi akun</h2>
                  <div class="section-subtitle">Field form tetap mengikuti backend yang sama untuk pembuatan user.</div>
                </div>
              </div>
              <div class="card-body-custom">
                <form action="/users" method="POST" id="createUserForm">
                  <div class="form-group">
                    <label class="form-label-custom" for="name">Nama Lengkap</label>
                    <input type="text" id="name" name="name" class="form-control-custom" placeholder="Contoh: Budi Santoso" required maxlength="150">
                  </div>

                  <div class="form-group">
                    <label class="form-label-custom" for="email">Email</label>
                    <input type="email" id="email" name="email" class="form-control-custom" placeholder="budi@company.com" required>
                  </div>

                  <div class="form-group">
                    <label class="form-label-custom" for="password">Password</label>
                    <div class="input-shell">
                      <input type="password" id="password" name="password" class="form-control-custom" placeholder="Minimal 6 karakter" required minlength="6">
                      <button type="button" class="btn-icon-app" data-password-toggle="#password" aria-label="Tampilkan password">
                        <i class="bi bi-eye"></i>
                      </button>
                    </div>
                  </div>

                  <div class="form-grid-2">
                    <div class="form-group">
                      <label class="form-label-custom" for="role">Role</label>
                      <select id="role" name="role" class="form-control-custom" required>
                        <option value="karyawan" selected>Karyawan</option>
                        <option value="teknisi">Teknisi</option>
                        <option value="admin">Admin</option>
                      </select>
                    </div>
                    <div class="form-group">
                      <label class="form-label-custom" for="department">Departemen</label>
                      <input type="text" id="department" name="department" class="form-control-custom" placeholder="Finance, HR, IT">
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="form-label-custom" for="phone">Nomor Telepon</label>
                    <input type="text" id="phone" name="phone" class="form-control-custom" placeholder="081234567890">
                  </div>

                  <div class="form-actions">
                    <button type="submit" class="btn-primary-app">Buat Akun</button>
                    <a href="/users" class="btn-secondary-app">Batal</a>
                  </div>
                </form>
              </div>
            </section>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
