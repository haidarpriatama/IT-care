<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Dashboard IT Care Helpdesk - lihat statistik dan tiket terkini">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/navbar') %>
      <div class="page-content">

        <!-- ── Greeting ── -->
        <div class="section-gap">
          <h1 class="fw-bold" style="font-size:1.5rem; color:var(--text);">
            Halo, <span style="color:var(--accent);"><%= currentUser.name.split(' ')[0] %></span> 👋
          </h1>
          <p style="color:var(--text-muted); font-size:.9rem;">
            Selamat datang di IT Care Helpdesk.
            <% if (currentUser.role === 'admin') { %>
              Berikut ringkasan sistem hari ini.
            <% } else if (currentUser.role === 'teknisi') { %>
              Ini adalah tiket yang sedang ditugaskan kepada Anda.
            <% } else { %>
              Pantau tiket pengaduan IT Anda di sini.
            <% } %>
          </p>
        </div>

        <!-- ── Stats Cards ── -->
        <% if (currentUser.role === 'admin') { %>
        <div class="stats-grid section-gap">
          <div class="stat-card">
            <div class="stat-icon purple"><i class="bi bi-ticket-detailed"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= stats.total %></div>
              <div class="stat-label">Total Tiket</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-envelope-open"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= stats.open %></div>
              <div class="stat-label">Tiket Open</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon orange"><i class="bi bi-gear"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= stats.inProgress %></div>
              <div class="stat-label">Dalam Proses</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-check-circle"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= stats.resolved %></div>
              <div class="stat-label">Selesai</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon red"><i class="bi bi-x-circle"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= stats.rejected %></div>
              <div class="stat-label">Ditolak</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon indigo"><i class="bi bi-people"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= stats.totalUsers %></div>
              <div class="stat-label">Total User</div>
            </div>
          </div>
        </div>

        <% } else if (currentUser.role === 'teknisi') { %>
        <div class="stats-grid section-gap">
          <div class="stat-card">
            <div class="stat-icon purple"><i class="bi bi-clipboard-check"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= stats.assigned %></div>
              <div class="stat-label">Ditugaskan</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon orange"><i class="bi bi-gear-wide-connected"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= stats.inProgress %></div>
              <div class="stat-label">Sedang Ditangani</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-check2-all"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= stats.resolved %></div>
              <div class="stat-label">Diselesaikan</div>
            </div>
          </div>
        </div>

        <% } else { %>
        <div class="stats-grid section-gap">
          <div class="stat-card">
            <div class="stat-icon purple"><i class="bi bi-ticket-detailed"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= stats.total %></div>
              <div class="stat-label">Tiket Saya</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-envelope-open"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= stats.open %></div>
              <div class="stat-label">Open</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-check-circle"></i></div>
            <div class="stat-info">
              <div class="stat-value"><%= stats.resolved %></div>
              <div class="stat-label">Selesai</div>
            </div>
          </div>
        </div>
        <% } %>

        <!-- ── Recent Tickets Table ── -->
        <div class="card-custom">
          <div class="card-header-custom">
            <div class="card-title-custom">
              <i class="bi bi-clock-history"></i>
              <% if (currentUser.role === 'admin') { %>
                Tiket Terbaru
              <% } else if (currentUser.role === 'teknisi') { %>
                Tiket Ditugaskan ke Saya
              <% } else { %>
                Tiket Saya Terbaru
              <% } %>
            </div>
            <a href="/tickets" class="btn-secondary-custom" style="font-size:.8rem; padding:.4rem .9rem;">
              Lihat Semua <i class="bi bi-arrow-right"></i>
            </a>
          </div>

          <% if (recentTickets.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h4>Belum ada tiket</h4>
            <p>
              <% if (currentUser.role === 'karyawan') { %>
                <a href="/tickets/create" style="color:var(--accent);">Buat tiket pertama Anda</a>
              <% } else { %>
                Tidak ada tiket untuk ditampilkan.
              <% } %>
            </p>
          </div>
          <% } else { %>
          <div style="overflow-x:auto;">
            <table class="table-custom">
              <thead>
                <tr>
                  <th>#ID</th>
                  <th>Judul</th>
                  <th>Kategori</th>
                  <% if (currentUser.role !== 'karyawan') { %>
                  <th>Pemohon</th>
                  <% } %>
                  <th>Prioritas</th>
                  <th>Status</th>
                  <th>Tanggal</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% recentTickets.forEach(ticket => { %>
                <tr>
                  <td><span style="font-weight:700;color:var(--accent);">#<%= ticket.id %></span></td>
                  <td>
                    <a href="/tickets/<%= ticket.id %>" class="ticket-title">
                      <%= ticket.title %>
                    </a>
                    <% if (ticket.technician) { %>
                    <div class="text-muted-sm"><i class="bi bi-person-gear"></i> <%= ticket.technician %></div>
                    <% } %>
                  </td>
                  <td>
                    <% if (ticket.category) { %>
                    <span style="font-size:.8rem; background:#f1f5f9; padding:.2rem .6rem; border-radius:6px; color:var(--text-muted);">
                      <%= ticket.category %>
                    </span>
                    <% } else { %>
                    <span class="text-muted-sm">-</span>
                    <% } %>
                  </td>
                  <% if (currentUser.role !== 'karyawan') { %>
                  <td>
                    <span style="font-size:.85rem; font-weight:500;"><%= ticket.requester %></span>
                  </td>
                  <% } %>
                  <td>
                    <span class="badge-priority badge-<%= ticket.priority %>">
                      <%= ticket.priority === 'high' ? 'Tinggi' : ticket.priority === 'medium' ? 'Sedang' : 'Rendah' %>
                    </span>
                  </td>
                  <td>
                    <span class="badge-status badge-<%= ticket.status.replace('_','-') %>">
                      <%= ticket.status === 'open' ? 'Open' : ticket.status === 'in_progress' ? 'In Progress' : ticket.status === 'resolved' ? 'Selesai' : 'Ditolak' %>
                    </span>
                  </td>
                  <td class="text-muted-sm">
                    <%= new Date(ticket.created_at).toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' }) %>
                  </td>
                  <td>
                    <a href="/tickets/<%= ticket.id %>" class="btn-icon" title="Detail">
                      <i class="bi bi-eye"></i>
                    </a>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>

        <!-- ── Quick Actions (Karyawan) ── -->
        <% if (currentUser.role === 'karyawan') { %>
        <div class="card-custom" style="margin-top:1.5rem;">
          <div class="card-header-custom">
            <div class="card-title-custom"><i class="bi bi-lightning-charge"></i> Aksi Cepat</div>
          </div>
          <div class="card-body-custom">
            <a href="/tickets/create" class="btn-primary-custom">
              <i class="bi bi-plus-circle"></i> Buat Tiket Baru
            </a>
          </div>
        </div>
        <% } %>

      </div><!-- /page-content -->
    </div><!-- /main-content -->
  </div><!-- /app-layout -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
