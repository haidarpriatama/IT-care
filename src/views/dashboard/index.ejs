<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Dashboard IT Care Helpdesk - ringkasan tiket dan aktivitas terbaru">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/navbar') %>

      <main class="page-content">
        <section class="page-header">
          <div>
            <h1>Dashboard</h1>
            <p>
              <% if (currentUser.role === 'admin') { %>
                Ringkasan operasional helpdesk untuk memantau volume tiket, progres penanganan, dan kesehatan antrian kerja.
              <% } else if (currentUser.role === 'teknisi') { %>
                Fokus pada tiket yang ditugaskan ke Anda dan progres penanganannya.
              <% } else { %>
                Pantau status tiket yang Anda buat dan tindak lanjut dari tim IT.
              <% } %>
            </p>
          </div>

          <% if (currentUser.role === 'admin' || currentUser.role === 'karyawan') { %>
          <div class="page-actions">
            <a href="/tickets/create" class="btn-primary-app">Buat Tiket</a>
          </div>
          <% } %>
        </section>

        <% if (currentUser.role === 'admin') { %>
        <section class="metric-strip page-section">
          <div class="metric-card stat-card"><p class="metric-label stat-label">Total Tiket</p><div class="metric-value stat-value"><%= stats.total %></div><div class="metric-meta">Semua tiket aktif</div></div>
          <div class="metric-card stat-card"><p class="metric-label stat-label">Open</p><div class="metric-value stat-value"><%= stats.open %></div><div class="metric-meta">Menunggu tindak lanjut</div></div>
          <div class="metric-card stat-card"><p class="metric-label stat-label">Dalam Proses</p><div class="metric-value stat-value"><%= stats.inProgress %></div><div class="metric-meta">Sedang dikerjakan</div></div>
          <div class="metric-card stat-card"><p class="metric-label stat-label">Selesai</p><div class="metric-value stat-value"><%= stats.resolved %></div><div class="metric-meta">Tiket terselesaikan</div></div>
          <div class="metric-card stat-card"><p class="metric-label stat-label">Ditolak</p><div class="metric-value stat-value"><%= stats.rejected %></div><div class="metric-meta">Tidak dapat diproses</div></div>
          <div class="metric-card stat-card"><p class="metric-label stat-label">User Aktif</p><div class="metric-value stat-value"><%= stats.totalUsers %></div><div class="metric-meta">Akun terdaftar</div></div>
        </section>
        <% } else if (currentUser.role === 'teknisi') { %>
        <section class="metric-strip page-section">
          <div class="metric-card stat-card"><p class="metric-label stat-label">Assigned</p><div class="metric-value stat-value"><%= stats.assigned %></div><div class="metric-meta">Tiket yang ditugaskan</div></div>
          <div class="metric-card stat-card"><p class="metric-label stat-label">Dalam Proses</p><div class="metric-value stat-value"><%= stats.inProgress %></div><div class="metric-meta">Sedang dikerjakan</div></div>
          <div class="metric-card stat-card"><p class="metric-label stat-label">Selesai</p><div class="metric-value stat-value"><%= stats.resolved %></div><div class="metric-meta">Tiket selesai</div></div>
        </section>
        <% } else { %>
        <section class="metric-strip page-section">
          <div class="metric-card stat-card"><p class="metric-label stat-label">Tiket Saya</p><div class="metric-value stat-value"><%= stats.total %></div><div class="metric-meta">Total pengajuan aktif</div></div>
          <div class="metric-card stat-card"><p class="metric-label stat-label">Open</p><div class="metric-value stat-value"><%= stats.open %></div><div class="metric-meta">Menunggu diproses</div></div>
          <div class="metric-card stat-card"><p class="metric-label stat-label">Selesai</p><div class="metric-value stat-value"><%= stats.resolved %></div><div class="metric-meta">Sudah ditangani</div></div>
        </section>
        <% } %>

        <section class="data-card card-custom">
          <div class="toolbar">
            <div>
              <div class="toolbar-title">
                <% if (currentUser.role === 'admin') { %>Aktivitas tiket terbaru<% } else if (currentUser.role === 'teknisi') { %>Tiket yang ditugaskan<% } else { %>Tiket terbaru saya<% } %>
              </div>
              <div class="section-subtitle">Tampilan ringkas untuk tiket yang paling perlu diperhatikan saat ini.</div>
            </div>
            <div class="toolbar-controls">
              <a href="/tickets" class="btn-secondary-app">Lihat Semua</a>
            </div>
          </div>

          <% if (recentTickets.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h4>Belum ada tiket</h4>
            <p>
              <% if (currentUser.role === 'admin' || currentUser.role === 'karyawan') { %>
                <a href="/tickets/create">Buat tiket pertama</a> untuk mulai mengisi antrian helpdesk.
              <% } else { %>
                Tidak ada tiket yang sedang ditugaskan saat ini.
              <% } %>
            </p>
          </div>
          <% } else { %>
          <div class="table-wrap">
            <table class="data-table table-custom">
              <thead>
                <tr>
                  <th>#ID</th>
                  <th>Judul</th>
                  <th>Kategori</th>
                  <% if (currentUser.role !== 'karyawan') { %><th>Pemohon</th><% } %>
                  <th>Prioritas</th>
                  <th>Status</th>
                  <th>Tanggal</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% recentTickets.forEach(ticket => { %>
                <tr>
                  <td><a class="id-link" href="/tickets/<%= ticket.id %>">#<%= ticket.id %></a></td>
                  <td>
                    <div class="cell-stack">
                      <a href="/tickets/<%= ticket.id %>" class="ticket-title"><%= ticket.title %></a>
                      <% if (ticket.technician) { %><span class="cell-meta"><%= ticket.technician %></span><% } %>
                    </div>
                  </td>
                  <td><% if (ticket.category) { %><span class="chip"><%= ticket.category %></span><% } else { %><span class="text-muted-sm">-</span><% } %></td>
                  <% if (currentUser.role !== 'karyawan') { %><td><%= ticket.requester %></td><% } %>
                  <td><span class="badge-priority badge-<%= ticket.priority %>"><%= ticket.priority === 'high' ? 'Tinggi' : ticket.priority === 'medium' ? 'Sedang' : 'Rendah' %></span></td>
                  <td><span class="badge-status badge-<%= ticket.status %>"><%= ticket.status === 'open' ? 'Open' : ticket.status === 'in_progress' ? 'Dalam proses' : ticket.status === 'resolved' ? 'Selesai' : 'Ditolak' %></span></td>
                  <td class="text-muted-sm"><%= new Date(ticket.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                  <td>
                    <div class="table-actions">
                      <a href="/tickets/<%= ticket.id %>" class="btn-icon-app" title="Detail"><i class="bi bi-eye"></i></a>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </section>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
