<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Manajemen kategori tiket IT Care">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/navbar') %>

      <main class="page-content">
        <section class="page-header">
          <div>
            <h1>Kategori</h1>
            <p>Referensi kategori untuk mengelompokkan tiket agar pencarian dan pelaporan lebih konsisten.</p>
            <div class="page-header-meta">
              <span class="badge-count"><%= categories.length %> kategori</span>
            </div>
          </div>
        </section>

        <section class="data-card card-custom">
          <div class="toolbar">
            <form method="GET" action="/categories" class="toolbar-search toolbar-search-inline" role="search">
              <div class="toolbar-search-main">
                <i class="bi bi-search"></i>
                <input type="text" name="search" class="toolbar-search-field search-input" placeholder="Cari nama atau deskripsi kategori..." value="<%= search %>" id="categorySearch">
              </div>
              <button type="submit" class="btn-secondary-app">Cari</button>
              <% if (search) { %>
              <a href="/categories" class="btn-secondary-app">Reset</a>
              <% } %>
            </form>

            <% if (currentUser.role === 'admin') { %>
            <div class="toolbar-controls">
              <a href="/categories/create" class="btn-primary-app" id="btnCreateCategory">Tambah Kategori</a>
            </div>
            <% } %>
          </div>

          <% if (categories.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-tags"></i>
            <h4>Tidak ada kategori ditemukan</h4>
            <p>
              <% if (search) { %>
                Coba kata kunci lain.
              <% } else if (currentUser.role === 'admin') { %>
                <a href="/categories/create">Buat kategori pertama.</a>
              <% } else { %>
                Belum ada kategori yang tersedia.
              <% } %>
            </p>
          </div>
          <% } else { %>
          <div class="table-wrap">
            <table class="data-table table-custom">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Nama Kategori</th>
                  <th>Deskripsi</th>
                  <% if (currentUser.role === 'admin') { %><th>Aksi</th><% } %>
                </tr>
              </thead>
              <tbody>
                <% categories.forEach((cat, index) => { %>
                <tr>
                  <td class="text-muted-sm"><%= index + 1 %></td>
                  <td>
                    <div class="entity-cell">
                      <div class="entity-icon"><i class="bi bi-tag"></i></div>
                      <span class="cell-title"><%= cat.name %></span>
                    </div>
                  </td>
                  <td class="text-muted-sm"><%= cat.description || '-' %></td>
                  <% if (currentUser.role === 'admin') { %>
                  <td>
                    <div class="table-actions action-inline">
                      <a href="/categories/<%= cat.id %>/edit" class="btn-icon-app" title="Edit"><i class="bi bi-pencil"></i></a>
                      <form method="POST" action="/categories/<%= cat.id %>?_method=DELETE" data-confirm="Hapus kategori '<%= cat.name %>'? Tiket yang memakai kategori ini akan kehilangan kategorinya.">
                        <button type="submit" class="btn-icon-app danger" title="Hapus"><i class="bi bi-trash3"></i></button>
                      </form>
                    </div>
                  </td>
                  <% } %>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </section>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
