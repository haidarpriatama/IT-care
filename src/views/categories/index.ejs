<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Manajemen Kategori IT Care">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/navbar') %>
      <div class="page-content">

        <div class="action-bar">
          <div>
            <div class="action-bar-title"><i class="bi bi-tags" style="color:var(--accent);"></i> Kategori</div>
            <div style="font-size:.8rem; color:var(--text-muted);">Kelola kategori tiket pengaduan</div>
          </div>
          <% if (currentUser.role === 'admin') { %>
          <a href="/categories/create" class="btn-primary-custom" id="btnCreateCategory">
            <i class="bi bi-plus-lg"></i> Tambah Kategori
          </a>
          <% } %>
        </div>

        <!-- Search -->
        <div class="card-custom section-gap">
          <div class="card-body-custom" style="padding:1rem 1.5rem;">
            <form method="GET" action="/categories">
              <div class="filter-bar">
                <input type="text" name="search" class="search-input"
                  placeholder="Cari nama atau deskripsi kategori..." value="<%= search %>"
                  id="categorySearch">
                <button type="submit" class="btn-primary-custom">
                  <i class="bi bi-search"></i> Cari
                </button>
                <% if (search) { %>
                <a href="/categories" class="btn-secondary-custom">
                  <i class="bi bi-x-lg"></i> Reset
                </a>
                <% } %>
              </div>
            </form>
          </div>
        </div>

        <!-- Categories Table -->
        <div class="card-custom">
          <% if (categories.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-tags"></i>
            <h4>Tidak ada kategori ditemukan</h4>
            <p>
              <% if (search) { %>Coba kata kunci lain.<% } else { %>
                <% if (currentUser.role === 'admin') { %>
                  <a href="/categories/create" style="color:var(--accent);">Buat kategori pertama.</a>
                <% } %>
              <% } %>
            </p>
          </div>
          <% } else { %>
          <div style="overflow-x:auto;">
            <table class="table-custom">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Nama Kategori</th>
                  <th>Deskripsi</th>
                  <th>Dibuat</th>
                  <% if (currentUser.role === 'admin') { %><th>Aksi</th><% } %>
                </tr>
              </thead>
              <tbody>
                <% categories.forEach((cat, index) => { %>
                <tr>
                  <td><span style="font-weight:600; color:var(--text-muted);"><%= index + 1 %></span></td>
                  <td>
                    <div style="display:flex; align-items:center; gap:.6rem;">
                      <div style="width:32px; height:32px; background:var(--accent-soft); border-radius:8px;
                        display:flex; align-items:center; justify-content:center; color:var(--accent);">
                        <i class="bi bi-tag"></i>
                      </div>
                      <span style="font-weight:600; font-size:.9rem;"><%= cat.name %></span>
                    </div>
                  </td>
                  <td style="font-size:.85rem; color:var(--text-muted); max-width:300px;">
                    <%= cat.description || '-' %>
                  </td>
                  <td class="text-muted-sm">
                    <%= new Date(cat.created_at).toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' }) %>
                  </td>
                  <% if (currentUser.role === 'admin') { %>
                  <td>
                    <div style="display:flex; gap:.35rem;">
                      <a href="/categories/<%= cat.id %>/edit" class="btn-icon" title="Edit">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form method="POST" action="/categories/<%= cat.id %>?_method=DELETE" style="display:inline;"
                        onsubmit="return confirm('Hapus kategori \'<%= cat.name %>\'? Tiket yang menggunakan kategori ini akan kehilangan kategorinya.')">
                        <button type="submit" class="btn-icon danger" title="Hapus">
                          <i class="bi bi-trash3"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                  <% } %>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>

      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
