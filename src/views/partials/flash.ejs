<div class="flash-container" id="flashContainer">
  <% if (messages && messages.success && messages.success.length > 0) { %>
    <% messages.success.forEach(msg => { %>
      <div class="flash-message success" role="alert">
        <i class="bi bi-check-circle flash-icon"></i>
        <span class="flash-text"><%= msg %></span>
        <button type="button" class="flash-close" aria-label="Tutup pesan"><i class="bi bi-x"></i></button>
      </div>
    <% }) %>
  <% } %>

  <% if (messages && messages.error && messages.error.length > 0) { %>
    <% messages.error.forEach(msg => { %>
      <div class="flash-message error" role="alert">
        <i class="bi bi-exclamation-circle flash-icon"></i>
        <span class="flash-text"><%= msg %></span>
        <button type="button" class="flash-close" aria-label="Tutup pesan"><i class="bi bi-x"></i></button>
      </div>
    <% }) %>
  <% } %>

  <% if (messages && messages.warning && messages.warning.length > 0) { %>
    <% messages.warning.forEach(msg => { %>
      <div class="flash-message warning" role="alert">
        <i class="bi bi-exclamation-triangle flash-icon"></i>
        <span class="flash-text"><%= msg %></span>
        <button type="button" class="flash-close" aria-label="Tutup pesan"><i class="bi bi-x"></i></button>
      </div>
    <% }) %>
  <% } %>
</div>
