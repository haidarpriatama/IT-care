<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Buat tiket pengaduan IT baru di IT Care">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/navbar') %>

      <main class="page-content">
        <section class="page-header">
          <div>
            <h1>Buat Tiket</h1>
            <p>Isi detail masalah sejelas mungkin agar tim IT bisa memprioritaskan dan menindaklanjuti dengan cepat.</p>
          </div>
          <div class="page-actions">
            <a href="/tickets" class="btn-secondary-app">Kembali</a>
          </div>
        </section>

        <div class="row">
          <div class="col-xl-8 col-lg-9">
            <section class="form-panel data-card">
              <div class="card-header-custom">
                <div>
                  <h2 class="panel-title">Informasi tiket</h2>
                  <div class="section-subtitle">Semua field tetap memakai route dan nama variabel yang sama seperti implementasi backend saat ini.</div>
                </div>
              </div>
              <div class="card-body-custom">
                <div class="helper-strip page-section">
                  <strong>Catatan singkat</strong>
                  Sertakan gejala, lokasi, dan dampak ke pekerjaan. Gunakan prioritas tinggi hanya jika pekerjaan utama benar-benar terhenti.
                </div>

                <form action="/tickets" method="POST" id="createTicketForm">
                  <div class="form-group">
                    <label class="form-label-custom" for="title">Judul Tiket</label>
                    <input type="text" id="title" name="title" class="form-control-custom" placeholder="Contoh: Komputer tidak bisa menyala di meja 12" required maxlength="200">
                    <div class="form-help">Gunakan judul singkat yang langsung menjelaskan isu utama.</div>
                  </div>

                  <div class="form-group">
                    <label class="form-label-custom" for="category_id">Kategori</label>
                    <select id="category_id" name="category_id" class="form-control-custom">
                      <option value="">Pilih kategori</option>
                      <% categories.forEach(cat => { %>
                      <option value="<%= cat.id %>"><%= cat.name %></option>
                      <% }) %>
                    </select>
                  </div>

                  <div class="form-group">
                    <label class="form-label-custom" for="description">Deskripsi Masalah</label>
                    <textarea id="description" name="description" class="form-control-custom" placeholder="Jelaskan gejala, waktu kejadian, dan langkah yang sudah dicoba." rows="5" required></textarea>
                    <div class="form-help">Masukkan konteks yang cukup agar teknisi tidak perlu menebak kondisi di lapangan.</div>
                  </div>

                  <div class="form-grid-2">
                    <div class="form-group">
                      <label class="form-label-custom" for="location">Lokasi / Ruangan</label>
                      <input type="text" id="location" name="location" class="form-control-custom" placeholder="Contoh: Finance Lt. 2">
                    </div>
                    <div class="form-group">
                      <label class="form-label-custom" for="priority">Prioritas</label>
                      <select id="priority" name="priority" class="form-control-custom">
                        <option value="low">Rendah</option>
                        <option value="medium" selected>Sedang</option>
                        <option value="high">Tinggi</option>
                      </select>
                    </div>
                  </div>

                  <div class="form-actions">
                    <button type="submit" class="btn-primary-app" id="submitBtn">Kirim Tiket</button>
                    <a href="/tickets" class="btn-secondary-app">Batal</a>
                  </div>
                </form>
              </div>
            </section>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
