<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Trash tiket IT Care">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/navbar') %>

      <main class="page-content">
        <section class="page-header">
          <div>
            <h1>Trash</h1>
            <p>Tiket yang dipindahkan sementara sebelum dihapus permanen atau dipulihkan kembali.</p>
            <div class="page-header-meta">
              <span class="badge-count"><%= tickets.length %> item</span>
            </div>
          </div>
          <div class="page-actions">
            <a href="/tickets" class="btn-secondary-app">Kembali ke Tiket</a>
          </div>
        </section>

        <section class="data-card card-custom">
          <% if (tickets.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-trash3"></i>
            <h4>Trash kosong</h4>
            <p>Tidak ada tiket yang dihapus sementara.</p>
          </div>
          <% } else { %>
          <div class="table-wrap">
            <table class="data-table table-custom">
              <thead>
                <tr>
                  <th>#ID</th>
                  <th>Judul</th>
                  <th>Kategori</th>
                  <th>Pemohon</th>
                  <th>Prioritas</th>
                  <th>Status Terakhir</th>
                  <th>Dihapus Pada</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% tickets.forEach(ticket => { %>
                <tr>
                  <td><span class="id-link">#<%= ticket.id %></span></td>
                  <td>
                    <div class="cell-stack">
                      <span class="ticket-title"><%= ticket.title %></span>
                      <span class="cell-meta">Tersimpan di trash</span>
                    </div>
                  </td>
                  <td><% if (ticket.category) { %><span class="chip"><%= ticket.category %></span><% } else { %><span class="text-muted-sm">-</span><% } %></td>
                  <td><%= ticket.requester %></td>
                  <td><span class="badge-priority badge-<%= ticket.priority %>"><%= ticket.priority === 'high' ? 'Tinggi' : ticket.priority === 'medium' ? 'Sedang' : 'Rendah' %></span></td>
                  <td><span class="badge-status badge-<%= ticket.status %>"><%= ticket.status === 'open' ? 'Open' : ticket.status === 'in_progress' ? 'Dalam proses' : ticket.status === 'resolved' ? 'Selesai' : 'Ditolak' %></span></td>
                  <td class="text-muted-sm"><%= new Date(ticket.deleted_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                  <td>
                    <div class="table-actions action-inline">
                      <form method="POST" action="/tickets/<%= ticket.id %>/restore">
                        <button type="submit" class="btn-icon-app success" title="Pulihkan Tiket"><i class="bi bi-arrow-counterclockwise"></i></button>
                      </form>
                      <form method="POST" action="/tickets/<%= ticket.id %>/hard?_method=DELETE" data-confirm="Hapus permanen tiket ini? Tindakan ini tidak bisa dibatalkan.">
                        <button type="submit" class="btn-icon-app danger" title="Hapus Permanen"><i class="bi bi-x-octagon"></i></button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </section>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
