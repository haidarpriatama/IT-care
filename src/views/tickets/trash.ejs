<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Trash - tiket yang telah dihapus sementara">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/navbar') %>
      <div class="page-content">

        <div class="action-bar">
          <div>
            <div class="action-bar-title"><i class="bi bi-trash3" style="color:var(--danger);"></i> Trash</div>
            <div style="font-size:.8rem; color:var(--text-muted);">Tiket yang telah dihapus sementara (<%= tickets.length %> item)</div>
          </div>
          <a href="/tickets" class="btn-secondary-custom">
            <i class="bi bi-arrow-left"></i> Kembali ke Tiket
          </a>
        </div>

        <div class="card-custom">
          <% if (tickets.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-trash3"></i>
            <h4>Trash Kosong</h4>
            <p>Tidak ada tiket yang dihapus sementara.</p>
          </div>
          <% } else { %>
          <div style="overflow-x:auto;">
            <table class="table-custom">
              <thead>
                <tr>
                  <th>#ID</th>
                  <th>Judul</th>
                  <th>Kategori</th>
                  <th>Pemohon</th>
                  <th>Prioritas</th>
                  <th>Status Terakhir</th>
                  <th>Dihapus Pada</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% tickets.forEach(ticket => { %>
                <tr>
                  <td><span style="font-weight:700; color:var(--danger);">#<%= ticket.id %></span></td>
                  <td>
                    <span style="font-weight:600; color:var(--text); text-decoration:line-through; opacity:.6;">
                      <%= ticket.title %>
                    </span>
                  </td>
                  <td>
                    <% if (ticket.category) { %>
                    <span style="font-size:.8rem; background:#f1f5f9; padding:.2rem .6rem; border-radius:6px; color:var(--text-muted);">
                      <%= ticket.category %>
                    </span>
                    <% } else { %><span class="text-muted-sm">-</span><% } %>
                  </td>
                  <td style="font-size:.85rem;"><%= ticket.requester %></td>
                  <td>
                    <span class="badge-priority badge-<%= ticket.priority %>">
                      <%= ticket.priority === 'high' ? 'Tinggi' : ticket.priority === 'medium' ? 'Sedang' : 'Rendah' %>
                    </span>
                  </td>
                  <td>
                    <span class="badge-status badge-<%= ticket.status %>">
                      <%= ticket.status === 'open' ? 'Open' : ticket.status === 'in_progress' ? 'In Progress' : ticket.status === 'resolved' ? 'Selesai' : 'Ditolak' %>
                    </span>
                  </td>
                  <td class="text-muted-sm">
                    <%= new Date(ticket.deleted_at).toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' }) %>
                  </td>
                  <td>
                    <div style="display:flex; gap:.35rem;">
                      <!-- Restore -->
                      <form method="POST" action="/tickets/<%= ticket.id %>/restore" style="display:inline;">
                        <button type="submit" class="btn-icon success" title="Pulihkan Tiket">
                          <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                      </form>
                      <!-- Hard Delete -->
                      <form method="POST" action="/tickets/<%= ticket.id %>/hard?_method=DELETE" style="display:inline;"
                        onsubmit="return confirm('Hapus permanen tiket ini? Tindakan ini tidak bisa dibatalkan!')">
                        <button type="submit" class="btn-icon danger" title="Hapus Permanen">
                          <i class="bi bi-x-octagon"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>

      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
