<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Edit tiket IT Care">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/navbar') %>
      <div class="page-content">

        <div class="action-bar">
          <div>
            <div class="action-bar-title">
              <i class="bi bi-pencil-square" style="color:var(--accent);"></i> Edit Tiket #<%= ticket.id %>
            </div>
            <div style="font-size:.8rem; color:var(--text-muted);">Perbarui informasi tiket</div>
          </div>
          <a href="/tickets/<%= ticket.id %>" class="btn-secondary-custom">
            <i class="bi bi-arrow-left"></i> Kembali ke Detail
          </a>
        </div>

        <div style="max-width:720px;">
          <div class="card-custom">
            <div class="card-header-custom">
              <div class="card-title-custom">
                <i class="bi bi-file-earmark-text"></i> Informasi Tiket
              </div>
              <span class="badge-status badge-<%= ticket.status %>">
                <%= ticket.status === 'open' ? 'Open' : ticket.status === 'in_progress' ? 'In Progress' : ticket.status === 'resolved' ? 'Selesai' : 'Ditolak' %>
              </span>
            </div>
            <div class="card-body-custom">
              <form action="/tickets/<%= ticket.id %>?_method=PUT" method="POST">

                <!-- Admin: semua field -->
                <% if (currentUser.role === 'admin') { %>

                <div class="form-group">
                  <label class="form-label-custom" for="title">Judul Tiket *</label>
                  <input type="text" id="title" name="title" class="form-control-custom"
                    value="<%= ticket.title %>" required maxlength="200">
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.25rem;">
                  <div class="form-group">
                    <label class="form-label-custom" for="category_id">Kategori</label>
                    <select id="category_id" name="category_id" class="form-control-custom">
                      <option value="">-- Tanpa Kategori --</option>
                      <% categories.forEach(cat => { %>
                      <option value="<%= cat.id %>" <%= ticket.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="form-group">
                    <label class="form-label-custom" for="priority">Prioritas</label>
                    <select id="priority" name="priority" class="form-control-custom">
                      <option value="low" <%= ticket.priority === 'low' ? 'selected' : '' %>>Rendah</option>
                      <option value="medium" <%= ticket.priority === 'medium' ? 'selected' : '' %>>Sedang</option>
                      <option value="high" <%= ticket.priority === 'high' ? 'selected' : '' %>>Tinggi</option>
                    </select>
                  </div>
                </div>

                <div class="form-group">
                  <label class="form-label-custom" for="description">Deskripsi Masalah *</label>
                  <textarea id="description" name="description" class="form-control-custom" rows="4" required><%= ticket.description %></textarea>
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.25rem;">
                  <div class="form-group">
                    <label class="form-label-custom" for="location">Lokasi</label>
                    <input type="text" id="location" name="location" class="form-control-custom"
                      value="<%= ticket.location || '' %>">
                  </div>
                  <div class="form-group">
                    <label class="form-label-custom" for="status">Status</label>
                    <select id="status" name="status" class="form-control-custom">
                      <option value="open" <%= ticket.status === 'open' ? 'selected' : '' %>>Open</option>
                      <option value="in_progress" <%= ticket.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
                      <option value="resolved" <%= ticket.status === 'resolved' ? 'selected' : '' %>>Selesai</option>
                      <option value="rejected" <%= ticket.status === 'rejected' ? 'selected' : '' %>>Ditolak</option>
                    </select>
                  </div>
                </div>

                <div class="form-group">
                  <label class="form-label-custom" for="admin_note">Catatan Admin</label>
                  <textarea id="admin_note" name="admin_note" class="form-control-custom" rows="3"
                    placeholder="Catatan internal admin (tidak terlihat karyawan)..."><%= ticket.admin_note || '' %></textarea>
                </div>

                <% } else if (currentUser.role === 'teknisi') { %>

                <!-- Teknisi: hanya bisa ubah status -->
                <div style="background:#f8fafc; border-radius:10px; padding:1rem; margin-bottom:1.25rem;">
                  <div style="font-size:.8rem; color:var(--text-muted); margin-bottom:.5rem;">
                    <i class="bi bi-info-circle"></i> Sebagai teknisi, Anda hanya bisa mengubah status tiket.
                  </div>
                  <div style="font-weight:600; font-size:.9rem;"><%= ticket.title %></div>
                </div>

                <div class="form-group">
                  <label class="form-label-custom" for="status">Ubah Status</label>
                  <select id="status" name="status" class="form-control-custom">
                    <option value="in_progress" <%= ticket.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
                    <option value="resolved" <%= ticket.status === 'resolved' ? 'selected' : '' %>>Selesai</option>
                    <option value="rejected" <%= ticket.status === 'rejected' ? 'selected' : '' %>>Ditolak</option>
                  </select>
                </div>

                <% } else { %>

                <!-- Karyawan: edit field dasar saja -->
                <div class="form-group">
                  <label class="form-label-custom" for="title">Judul Tiket *</label>
                  <input type="text" id="title" name="title" class="form-control-custom"
                    value="<%= ticket.title %>" required maxlength="200">
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.25rem;">
                  <div class="form-group">
                    <label class="form-label-custom" for="category_id">Kategori</label>
                    <select id="category_id" name="category_id" class="form-control-custom">
                      <option value="">-- Tanpa Kategori --</option>
                      <% categories.forEach(cat => { %>
                      <option value="<%= cat.id %>" <%= ticket.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="form-group">
                    <label class="form-label-custom" for="priority">Prioritas</label>
                    <select id="priority" name="priority" class="form-control-custom">
                      <option value="low" <%= ticket.priority === 'low' ? 'selected' : '' %>>Rendah</option>
                      <option value="medium" <%= ticket.priority === 'medium' ? 'selected' : '' %>>Sedang</option>
                      <option value="high" <%= ticket.priority === 'high' ? 'selected' : '' %>>Tinggi</option>
                    </select>
                  </div>
                </div>

                <div class="form-group">
                  <label class="form-label-custom" for="description">Deskripsi Masalah *</label>
                  <textarea id="description" name="description" class="form-control-custom" rows="4" required><%= ticket.description %></textarea>
                </div>

                <div class="form-group">
                  <label class="form-label-custom" for="location">Lokasi</label>
                  <input type="text" id="location" name="location" class="form-control-custom"
                    value="<%= ticket.location || '' %>">
                </div>

                <% } %>

                <div style="border-top:1px solid var(--border); padding-top:1.25rem; margin-top:.5rem; display:flex; gap:.75rem;">
                  <button type="submit" class="btn-primary-custom">
                    <i class="bi bi-floppy"></i> Simpan Perubahan
                  </button>
                  <a href="/tickets/<%= ticket.id %>" class="btn-secondary-custom">Batal</a>
                </div>

              </form>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
