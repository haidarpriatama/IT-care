<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Edit tiket IT Care">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/navbar') %>

      <main class="page-content">
        <section class="page-header">
          <div>
            <h1>Edit Tiket #<%= ticket.id %></h1>
            <p>Perbarui field yang memang diizinkan untuk role Anda tanpa mengubah alur backend dan status logic yang sudah ada.</p>
          </div>
          <div class="page-actions">
            <a href="/tickets/<%= ticket.id %>" class="btn-secondary-app">Kembali ke Detail</a>
          </div>
        </section>

        <div class="row">
          <div class="col-xl-8 col-lg-9">
            <section class="form-panel data-card">
              <div class="card-header-custom">
                <div>
                  <h2 class="panel-title">Perbarui informasi tiket</h2>
                  <div class="section-subtitle">Status saat ini: <span class="badge-status badge-<%= ticket.status %>"><%= ticket.status === 'open' ? 'Open' : ticket.status === 'in_progress' ? 'Dalam proses' : ticket.status === 'resolved' ? 'Selesai' : 'Ditolak' %></span></div>
                </div>
              </div>

              <div class="card-body-custom">
                <% if (currentUser.role === 'teknisi') { %>
                <div class="helper-strip page-section">
                  <strong>Akses teknisi</strong>
                  Anda hanya dapat memperbarui status tiket yang ditugaskan ke Anda.
                </div>
                <% } %>

                <form action="/tickets/<%= ticket.id %>?_method=PUT" method="POST">
                  <% if (currentUser.role === 'admin') { %>
                  <div class="form-group">
                    <label class="form-label-custom" for="title">Judul Tiket</label>
                    <input type="text" id="title" name="title" class="form-control-custom" value="<%= ticket.title %>" required maxlength="200">
                  </div>

                  <div class="form-grid-2">
                    <div class="form-group">
                      <label class="form-label-custom" for="category_id">Kategori</label>
                      <select id="category_id" name="category_id" class="form-control-custom">
                        <option value="">Tanpa kategori</option>
                        <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>" <%= ticket.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="form-group">
                      <label class="form-label-custom" for="priority">Prioritas</label>
                      <select id="priority" name="priority" class="form-control-custom">
                        <option value="low" <%= ticket.priority === 'low' ? 'selected' : '' %>>Rendah</option>
                        <option value="medium" <%= ticket.priority === 'medium' ? 'selected' : '' %>>Sedang</option>
                        <option value="high" <%= ticket.priority === 'high' ? 'selected' : '' %>>Tinggi</option>
                      </select>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="form-label-custom" for="description">Deskripsi Masalah</label>
                    <textarea id="description" name="description" class="form-control-custom" rows="5" required><%= ticket.description %></textarea>
                  </div>

                  <div class="form-grid-2">
                    <div class="form-group">
                      <label class="form-label-custom" for="location">Lokasi</label>
                      <input type="text" id="location" name="location" class="form-control-custom" value="<%= ticket.location || '' %>">
                    </div>
                    <div class="form-group">
                      <label class="form-label-custom" for="status">Status</label>
                      <select id="status" name="status" class="form-control-custom">
                        <option value="open" <%= ticket.status === 'open' ? 'selected' : '' %>>Open</option>
                        <option value="in_progress" <%= ticket.status === 'in_progress' ? 'selected' : '' %>>Dalam proses</option>
                        <option value="resolved" <%= ticket.status === 'resolved' ? 'selected' : '' %>>Selesai</option>
                        <option value="rejected" <%= ticket.status === 'rejected' ? 'selected' : '' %>>Ditolak</option>
                      </select>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="form-label-custom" for="admin_note">Catatan Admin</label>
                    <textarea id="admin_note" name="admin_note" class="form-control-custom" rows="4" placeholder="Catatan internal admin (tidak terlihat karyawan)..."><%= ticket.admin_note || '' %></textarea>
                  </div>
                  <% } else if (currentUser.role === 'teknisi') { %>
                  <div class="form-group">
                    <label class="form-label-custom" for="status">Ubah Status</label>
                    <select id="status" name="status" class="form-control-custom">
                      <option value="in_progress" <%= ticket.status === 'in_progress' ? 'selected' : '' %>>Dalam proses</option>
                      <option value="resolved" <%= ticket.status === 'resolved' ? 'selected' : '' %>>Selesai</option>
                      <option value="rejected" <%= ticket.status === 'rejected' ? 'selected' : '' %>>Ditolak</option>
                    </select>
                  </div>
                  <% } else { %>
                  <div class="form-group">
                    <label class="form-label-custom" for="title">Judul Tiket</label>
                    <input type="text" id="title" name="title" class="form-control-custom" value="<%= ticket.title %>" required maxlength="200">
                  </div>

                  <div class="form-grid-2">
                    <div class="form-group">
                      <label class="form-label-custom" for="category_id">Kategori</label>
                      <select id="category_id" name="category_id" class="form-control-custom">
                        <option value="">Tanpa kategori</option>
                        <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>" <%= ticket.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="form-group">
                      <label class="form-label-custom" for="priority">Prioritas</label>
                      <select id="priority" name="priority" class="form-control-custom">
                        <option value="low" <%= ticket.priority === 'low' ? 'selected' : '' %>>Rendah</option>
                        <option value="medium" <%= ticket.priority === 'medium' ? 'selected' : '' %>>Sedang</option>
                        <option value="high" <%= ticket.priority === 'high' ? 'selected' : '' %>>Tinggi</option>
                      </select>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="form-label-custom" for="description">Deskripsi Masalah</label>
                    <textarea id="description" name="description" class="form-control-custom" rows="5" required><%= ticket.description %></textarea>
                  </div>

                  <div class="form-group">
                    <label class="form-label-custom" for="location">Lokasi</label>
                    <input type="text" id="location" name="location" class="form-control-custom" value="<%= ticket.location || '' %>">
                  </div>
                  <% } %>

                  <div class="form-actions">
                    <button type="submit" class="btn-primary-app">Simpan Perubahan</button>
                    <a href="/tickets/<%= ticket.id %>" class="btn-secondary-app">Batal</a>
                  </div>
                </form>
              </div>
            </section>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
