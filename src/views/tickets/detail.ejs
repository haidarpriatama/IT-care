<%
  const statusLabel = (value) => ({ open: 'Open', in_progress: 'Dalam proses', resolved: 'Selesai', rejected: 'Ditolak' }[value] || value || '-');
  const priorityLabel = (value) => ({ high: 'Tinggi', medium: 'Sedang', low: 'Rendah' }[value] || value || '-');
%>
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Detail tiket IT Care Helpdesk">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/flash') %>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/navbar') %>

      <main class="page-content">
        <section class="page-header">
          <div>
            <h1>Tiket #<%= ticket.id %></h1>
            <p>Dibuat pada <%= new Date(ticket.created_at).toLocaleDateString('id-ID', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' }) %></p>
          </div>
          <div class="page-actions">
            <a href="/tickets" class="btn-secondary-app">Kembali</a>
            <% if ((currentUser.role === 'karyawan' && ticket.user_id === currentUser.id && ticket.status === 'open') || currentUser.role === 'admin') { %>
            <a href="/tickets/<%= ticket.id %>/edit" class="btn-primary-app">Edit Tiket</a>
            <% } %>
            <% if (currentUser.role === 'admin') { %>
            <form method="POST" action="/tickets/<%= ticket.id %>?_method=DELETE" data-confirm="Pindahkan tiket ini ke trash?">
              <button type="submit" class="btn-danger-custom">Hapus</button>
            </form>
            <% } %>
          </div>
        </section>

        <div class="detail-layout">
          <div>
            <section class="data-card card-custom page-section">
              <div class="card-body-custom">
                <div class="detail-summary">
                  <div>
                    <div class="detail-kicker">Tiket operasional</div>
                    <h2 class="detail-ticket-title"><%= ticket.title %></h2>
                  </div>
                  <div class="page-actions">
                    <span class="badge-priority badge-<%= ticket.priority %>"><%= priorityLabel(ticket.priority) %></span>
                    <span class="badge-status badge-<%= ticket.status %>"><%= statusLabel(ticket.status) %></span>
                  </div>
                </div>

                <div class="detail-meta ticket-meta">
                  <span class="ticket-meta-item"><i class="bi bi-person"></i><span><%= ticket.requester_name %> (<%= ticket.department || 'Tanpa departemen' %>)</span></span>
                  <% if (ticket.category_name) { %><span class="ticket-meta-item"><i class="bi bi-tag"></i><span><%= ticket.category_name %></span></span><% } %>
                  <% if (ticket.location) { %><span class="ticket-meta-item"><i class="bi bi-geo-alt"></i><span><%= ticket.location %></span></span><% } %>
                  <span class="ticket-meta-item"><i class="bi bi-person-gear"></i><span><%= ticket.technician_name || 'Belum ditugaskan' %></span></span>
                </div>
              </div>
            </section>

            <section class="data-card card-custom page-section">
              <div class="card-header-custom">
                <div>
                  <h2 class="panel-title">Deskripsi Masalah</h2>
                  <div class="section-subtitle">Informasi yang disampaikan pelapor.</div>
                </div>
              </div>
              <div class="card-body-custom">
                <p class="description-copy"><%= ticket.description %></p>
              </div>
            </section>

            <% if (ticket.admin_note || currentUser.role === 'admin') { %>
            <section class="data-card card-custom page-section">
              <div class="card-header-custom">
                <div>
                  <h2 class="panel-title">Catatan Admin</h2>
                  <div class="section-subtitle">Catatan koordinasi dan keputusan administratif.</div>
                </div>
              </div>
              <div class="card-body-custom">
                <% if (ticket.admin_note) { %>
                <p class="description-copy"><%= ticket.admin_note %></p>
                <% } else { %>
                <p class="text-muted-sm">Belum ada catatan admin.</p>
                <% } %>
              </div>
            </section>
            <% } %>

            <section class="data-card card-custom page-section">
              <div class="card-header-custom">
                <div>
                  <h2 class="panel-title">Catatan & Diskusi</h2>
                  <div class="section-subtitle"><%= notes.length %> catatan tercatat pada tiket ini.</div>
                </div>
              </div>
              <div class="card-body-custom">
                <% if (notes.length === 0) { %>
                <div class="empty-state compact">
                  <i class="bi bi-chat-left-text"></i>
                  <h4>Belum ada catatan</h4>
                  <p>Tiket ini belum memiliki diskusi tambahan.</p>
                </div>
                <% } else { %>
                <div class="note-list info-list">
                  <% notes.forEach(note => { %>
                  <div class="note-item">
                    <div class="note-avatar"><%= note.author_name ? note.author_name.charAt(0).toUpperCase() : '?' %></div>
                    <div class="cell-stack">
                      <div class="page-actions note-meta">
                        <span class="note-author"><%= note.author_name %></span>
                        <span class="badge-role-<%= note.author_role %>"><%= note.author_role %></span>
                        <span class="note-time"><%= new Date(note.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
                      </div>
                      <div class="note-text"><%= note.note %></div>
                    </div>
                  </div>
                  <% }) %>
                </div>
                <% } %>

                <% if (ticket.status !== 'resolved' && ticket.status !== 'rejected') { %>
                <div class="note-editor">
                  <form action="/tickets/<%= ticket.id %>/notes" method="POST">
                    <div class="form-group">
                      <label class="form-label-custom" for="note">Tambah Catatan</label>
                      <textarea id="note" name="note" class="form-control-custom" rows="4" placeholder="Tulis update penanganan atau informasi tambahan..." required></textarea>
                    </div>
                    <button type="submit" class="btn-primary-app">Kirim Catatan</button>
                  </form>
                </div>
                <% } %>
              </div>
            </section>
          </div>

          <div>
            <% if (currentUser.role === 'admin') { %>
            <section class="data-card card-custom page-section">
              <div class="card-header-custom">
                <div>
                  <h2 class="panel-title">Kelola Tiket</h2>
                  <div class="section-subtitle">Assignment teknisi dan perubahan status.</div>
                </div>
              </div>
              <div class="card-body-custom">
                <form action="/tickets/<%= ticket.id %>?_method=PUT" method="POST">
                  <input type="hidden" name="title" value="<%= ticket.title %>">
                  <input type="hidden" name="location" value="<%= ticket.location || '' %>">
                  <input type="hidden" name="priority" value="<%= ticket.priority %>">
                  <input type="hidden" name="category_id" value="<%= ticket.category_id || '' %>">
                  <textarea name="description" hidden><%= ticket.description %></textarea>
                  <textarea name="admin_note" hidden><%= ticket.admin_note || '' %></textarea>

                  <div class="form-group">
                    <label class="form-label-custom" for="technician_id">Assign Teknisi</label>
                    <select id="technician_id" name="technician_id" class="form-control-custom">
                      <option value="">Belum ditugaskan</option>
                      <% technicians.forEach(tech => { %>
                      <option value="<%= tech.id %>" <%= ticket.technician_id == tech.id ? 'selected' : '' %>><%= tech.name %></option>
                      <% }) %>
                    </select>
                  </div>

                  <div class="form-group">
                    <label class="form-label-custom" for="statusAdmin">Status</label>
                    <select id="statusAdmin" name="status" class="form-control-custom">
                      <option value="open" <%= ticket.status === 'open' ? 'selected' : '' %>>Open</option>
                      <option value="in_progress" <%= ticket.status === 'in_progress' ? 'selected' : '' %>>Dalam proses</option>
                      <option value="resolved" <%= ticket.status === 'resolved' ? 'selected' : '' %>>Selesai</option>
                      <option value="rejected" <%= ticket.status === 'rejected' ? 'selected' : '' %>>Ditolak</option>
                    </select>
                  </div>

                  <button type="submit" class="btn-primary-app btn-block">Simpan Perubahan</button>
                </form>
              </div>
            </section>
            <% } %>

            <% if (currentUser.role === 'teknisi' && ticket.technician_id === currentUser.id) { %>
            <section class="data-card card-custom page-section">
              <div class="card-header-custom">
                <div>
                  <h2 class="panel-title">Update Status</h2>
                  <div class="section-subtitle">Aksi teknisi untuk tiket yang sedang ditangani.</div>
                </div>
              </div>
              <div class="card-body-custom">
                <form action="/tickets/<%= ticket.id %>?_method=PUT" method="POST">
                  <input type="hidden" name="title" value="<%= ticket.title %>">
                  <textarea name="description" hidden><%= ticket.description %></textarea>

                  <div class="form-group">
                    <label class="form-label-custom" for="statusTeknisi">Status</label>
                    <select id="statusTeknisi" name="status" class="form-control-custom">
                      <option value="in_progress" <%= ticket.status === 'in_progress' ? 'selected' : '' %>>Dalam proses</option>
                      <option value="resolved" <%= ticket.status === 'resolved' ? 'selected' : '' %>>Selesai</option>
                      <option value="rejected" <%= ticket.status === 'rejected' ? 'selected' : '' %>>Ditolak</option>
                    </select>
                  </div>

                  <button type="submit" class="btn-primary-app btn-block">Update Status</button>
                </form>
              </div>
            </section>
            <% } %>

            <section class="data-card card-custom page-section">
              <div class="card-header-custom">
                <div>
                  <h2 class="panel-title">Info Tiket</h2>
                  <div class="section-subtitle">Ringkasan identitas tiket dan pemiliknya.</div>
                </div>
              </div>
              <div class="card-body-custom">
                <div class="key-value-list">
                  <div class="key-value-item"><div class="key-label">Status</div><div class="key-value"><span class="badge-status badge-<%= ticket.status %>"><%= statusLabel(ticket.status) %></span></div></div>
                  <div class="key-value-item"><div class="key-label">Prioritas</div><div class="key-value"><span class="badge-priority badge-<%= ticket.priority %>"><%= priorityLabel(ticket.priority) %></span></div></div>
                  <div class="key-value-item"><div class="key-label">Kategori</div><div class="key-value"><%= ticket.category_name || '-' %></div></div>
                  <div class="key-value-item"><div class="key-label">Pemohon</div><div class="key-value"><%= ticket.requester_name %></div><div class="cell-meta"><%= ticket.requester_email %></div></div>
                  <div class="key-value-item"><div class="key-label">Teknisi</div><div class="key-value"><%= ticket.technician_name || 'Belum ditugaskan' %></div></div>
                  <div class="key-value-item"><div class="key-label">Lokasi</div><div class="key-value"><%= ticket.location || '-' %></div></div>
                  <div class="key-value-item"><div class="key-label">Dibuat</div><div class="key-value"><%= new Date(ticket.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %></div></div>
                  <div class="key-value-item"><div class="key-label">Terakhir Diupdate</div><div class="key-value"><%= new Date(ticket.updated_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %></div></div>
                </div>
              </div>
            </section>

            <section class="data-card card-custom">
              <div class="card-header-custom">
                <div>
                  <h2 class="panel-title">Riwayat Status</h2>
                  <div class="section-subtitle">Jejak perubahan status dari waktu ke waktu.</div>
                </div>
              </div>
              <div class="card-body-custom">
                <% if (logs.length === 0) { %>
                <p class="text-muted-sm">Belum ada riwayat perubahan status.</p>
                <% } else { %>
                <div class="timeline">
                  <% logs.forEach(log => { %>
                  <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-label">
                      <% if (log.old_status) { %>
                        <span class="text-muted-sm timeline-status-old"><%= statusLabel(log.old_status) %></span>
                        ke <strong><%= statusLabel(log.new_status) %></strong>
                      <% } else { %>
                        Tiket dibuat sebagai <strong><%= statusLabel(log.new_status) %></strong>
                      <% } %>
                    </div>
                    <div class="timeline-time">oleh <%= log.changed_by_name %> · <%= new Date(log.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %></div>
                  </div>
                  <% }) %>
                </div>
                <% } %>
              </div>
            </section>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
